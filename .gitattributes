# Auto detect text files and perform LF normalization
* text=auto eol=lf

# -------------------------------------
# Source code
# -------------------------------------
*.go text eol=lf
*.py text eol=lf
*.rs text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.rb text eol=lf
*.java text eol=lf
*.cs text eol=lf
*.php text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf

# -------------------------------------
# Markup & data formats
# -------------------------------------
*.md text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.htm text eol=lf
*.xml text eol=lf
*.svg text eol=lf
*.css text eol=lf
